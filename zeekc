#! /usr/bin/env -S zeek -b --

@load base/misc/optparse
@load base/frameworks/cluster/controller/api
@load base/frameworks/cluster/controller/config
@load base/frameworks/cluster/controller/request

redef exit_only_after_terminate = T;

global controller_connected = F;

event Broker::peer_added(peer: Broker::EndpointInfo, msg: string)
	{
	controller_connected = T;
	}

event ClusterController::API::get_instances_response(reqid: string,
    instances: vector of ClusterController::Types::Instance)
	{
	local req = ClusterController::Request::lookup(reqid);
	if ( ClusterController::Request::is_null(req) )
		return;

	ClusterController::Request::finish(reqid);
	print(to_json(instances));
	exit(0);
	}

function setup_broker(res: Optparse::Result)
	{
	local hostport = res$opts["controller"]$vals[0];
	local hostport_vec = split_string(hostport, /:/);

	if ( |hostport_vec| != 2 )
		{
		print(fmt("error: invalid host/port specification '%s'", hostport));
		exit(1);
		}

	local chost = hostport_vec[0];
	local cport = count_to_port(to_count(hostport_vec[1]), tcp);

	Broker::subscribe(ClusterController::topic);

	Broker::auto_publish(ClusterController::topic, ClusterController::API::get_instances_request);
	Broker::auto_publish(ClusterController::topic, ClusterController::API::set_configuration_request);

	Broker::peer(chost, cport, ClusterController::connect_retry);
	}

function run_instances(res: Optparse::Result)
	{
	setup_broker(res);

	when ( controller_connected )
		{
		local req = ClusterController::Request::create();
		event ClusterController::API::get_instances_request(req$id);
		}
        }

function run_set_config(res: Optparse::Result)
	{
	print(res$unparsed);
        }

event zeek_init() {
	local opts: Optparse::OptVec = {
	    Optparse::Opt($name="h", $longname="help", $desc="Show help output"),
	    Optparse::Opt($longname="controller", $args_label="HOST:PORT",
	    $args_min=1, $default_vals=vector("127.0.0.1:2150"),
	    $desc="IP addresss and port of the controller")
	};

	local args: Optparse::ArgVec = {
	    Optparse::Arg($name="instances", $desc="Show connected instances"),
	    Optparse::Arg($name="set-config", $desc="Set node configuration for entire cluster")
	};

	local parser = Optparse::make_arg_parser("zeekc", args, opts, "A zeekc prototype.");
	local res = Optparse::parse(parser); # defaults to processing zeek_script_args global

	if ( "help" in res$opts )
		{
		Optparse::print_parser(parser);
		exit(0);
		}

        if ( ! res?$arg )
		{
		print("Please provide a command to run.");
		exit(1);
		}

	switch (res$arg$name)
		{
		case "instances":
			run_instances(res);
			break;
		case "set-config":
			run_set_config(res);
			break;
		}
}
